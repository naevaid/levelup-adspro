APP_ENV=production
APP_DOMAIN=adspro.naeva.id
ACME_EMAIL=admin@naeva.id

POSTGRES_DB=levelup_adspro
POSTGRES_USER=levelup
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql://levelup:replace-me@postgres:5432/levelup_adspro

REDIS_URL=redis://redis:6379

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=levelup
MINIO_SECRET_KEY=replace-me
MINIO_BUCKET_RAW_CAPTURE=raw-capture
MINIO_BUCKET_EXPORTS=exports

JWT_SECRET=replace-me-with-a-strong-secret
APP_BASE_URL=https://adspro.naeva.id
PASSWORD_RESET_TTL_MINUTES=60
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=465
MAIL_USERNAME=replace-with-mail-username
MAIL_PASSWORD=replace-with-mail-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="LevelUP adsPRO"
WORKER_QUEUE_NAME=bootstrap-jobs

PAYMENT_BASE_URL=https://payment.naeva.id/api/v1
PAYMENT_APP_ID=replace-with-payment-app-id
PAYMENT_SECRET_KEY=replace-with-payment-secret-key
BILLING_CALLBACK_URL=https://adspro.naeva.id/api/billing/payment/callback

NEXT_PUBLIC_API_BASE_URL=https://adspro.naeva.id/api
NEXT_PUBLIC_APP_ENV=production
