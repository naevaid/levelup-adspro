generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

enum MembershipRole {
  OWNER
  MANAGER
  STAFF
  AGENCY_ADMIN
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum PlanStatus {
  ACTIVE
  INACTIVE
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum MarketplaceCode {
  SHOPEE
  TIKTOK_SHOP
}

enum ShopStatus {
  ACTIVE
  DISCONNECTED
  SUSPENDED
}

enum ExtensionSessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum CaptureMode {
  OWNED
  PUBLIC
}

enum IngestionBatchStatus {
  ACCEPTED
  FAILED
  PROCESSING
  COMPLETED
}

enum RawPayloadObjectStatus {
  STORED
  FAILED
  EXPIRED
}

enum CategoryFeeStoreType {
  NON_STAR
  STAR
  MALL
}

model User {
  id                   String          @id @default(uuid()) @db.Uuid
  email                String          @unique
  passwordHash         String          @map("password_hash")
  name                 String
  status               UserStatus      @default(ACTIVE)
  lastLoginAt          DateTime?       @map("last_login_at")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  ownedOrganizations   Organization[]  @relation("OrganizationOwner")
  memberships          Membership[]
  userSessions         UserSession[]
  extensionSessions    ExtensionSession[]
  invitedMemberships   Membership[]    @relation("MembershipInvitedBy")

  @@map("users")
}

model Organization {
  id             String             @id @default(uuid()) @db.Uuid
  name           String
  slug           String             @unique
  ownerUserId    String             @map("owner_user_id") @db.Uuid
  status         OrganizationStatus @default(ACTIVE)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  ownerUser      User               @relation("OrganizationOwner", fields: [ownerUserId], references: [id])
  memberships    Membership[]
  userSessions   UserSession[]
  subscription   Subscription?
  shops          Shop[]
  extensionSessions ExtensionSession[]
  ingestionBatches IngestionBatch[]
  rawPayloadObjects RawPayloadObject[]
  marketplaceCategoryFees MarketplaceCategoryFee[]

  @@index([ownerUserId])
  @@map("organizations")
}

model Membership {
  id               String           @id @default(uuid()) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  userId           String           @map("user_id") @db.Uuid
  role             MembershipRole
  status           MembershipStatus @default(ACTIVE)
  invitedByUserId  String?          @map("invited_by_user_id") @db.Uuid
  joinedAt         DateTime?        @map("joined_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  organization     Organization     @relation(fields: [organizationId], references: [id])
  user             User             @relation(fields: [userId], references: [id])
  invitedByUser    User?            @relation("MembershipInvitedBy", fields: [invitedByUserId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, role])
  @@map("memberships")
}

model UserSession {
  id                   String        @id @default(uuid()) @db.Uuid
  userId               String        @map("user_id") @db.Uuid
  activeOrganizationId String        @map("active_organization_id") @db.Uuid
  sessionTokenHash     String        @unique @map("session_token_hash")
  expiresAt            DateTime      @map("expires_at")
  lastSeenAt           DateTime      @map("last_seen_at")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  user                 User          @relation(fields: [userId], references: [id])
  activeOrganization   Organization  @relation(fields: [activeOrganizationId], references: [id])

  @@index([userId])
  @@index([activeOrganizationId])
  @@map("user_sessions")
}

model Plan {
  id              String             @id @default(uuid()) @db.Uuid
  code            String             @unique
  name            String
  billingInterval BillingInterval    @map("billing_interval")
  shopLimit       Int                @map("shop_limit")
  memberLimit     Int                @map("member_limit")
  historyDays     Int                @map("history_days")
  featuresJson    Json               @map("features_json")
  status          PlanStatus         @default(ACTIVE)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  subscriptions   Subscription[]

  @@map("plans")
}

model Subscription {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @unique @map("organization_id") @db.Uuid
  planId            String             @map("plan_id") @db.Uuid
  status            SubscriptionStatus @default(TRIALING)
  startsAt          DateTime           @map("starts_at")
  endsAt            DateTime?          @map("ends_at")
  autoRenew         Boolean            @default(false) @map("auto_renew")
  provider          String
  providerReference String?            @map("provider_reference")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  organization      Organization       @relation(fields: [organizationId], references: [id])
  plan              Plan               @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([organizationId, status])
  @@map("subscriptions")
}

model Marketplace {
  id        String          @id @default(uuid()) @db.Uuid
  code      MarketplaceCode @unique
  name      String
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  shops     Shop[]
  categoryFees MarketplaceCategoryFee[]

  @@map("marketplaces")
}

model MarketplaceCategoryFee {
  id                String               @id @default(uuid()) @db.Uuid
  organizationId    String               @map("organization_id") @db.Uuid
  marketplaceId     String               @map("marketplace_id") @db.Uuid
  storeType         CategoryFeeStoreType @map("store_type")
  primaryCategory   String               @map("primary_category")
  secondaryCategory String?              @map("secondary_category")
  categoryName      String               @map("category_name")
  feePercent        Float                @map("fee_percent")
  isActive          Boolean              @default(true) @map("is_active")
  notes             String?
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  organization      Organization         @relation(fields: [organizationId], references: [id])
  marketplace       Marketplace          @relation(fields: [marketplaceId], references: [id])

  @@unique([organizationId, marketplaceId, storeType, primaryCategory, secondaryCategory, categoryName])
  @@index([organizationId, marketplaceId, storeType, isActive])
  @@index([organizationId])
  @@index([marketplaceId])
  @@map("marketplace_category_fees")
}

model Shop {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @map("organization_id") @db.Uuid
  marketplaceId     String             @map("marketplace_id") @db.Uuid
  externalId        String             @map("external_id")
  name              String?
  status            ShopStatus         @default(ACTIVE)
  metadataJson      Json               @default("{}") @map("metadata_json")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  organization      Organization       @relation(fields: [organizationId], references: [id])
  marketplace       Marketplace        @relation(fields: [marketplaceId], references: [id])
  extensionSessions ExtensionSession[]
  ingestionBatches  IngestionBatch[]
  rawPayloadObjects RawPayloadObject[]

  @@unique([organizationId, marketplaceId, externalId])
  @@index([organizationId])
  @@index([marketplaceId])
  @@map("shops")
}

model ExtensionSession {
  id               String                 @id @default(uuid()) @db.Uuid
  organizationId   String                 @map("organization_id") @db.Uuid
  userId           String                 @map("user_id") @db.Uuid
  shopId           String?                @map("shop_id") @db.Uuid
  deviceLabel      String                 @map("device_label")
  extensionVersion String                 @map("extension_version")
  sessionTokenHash String                 @unique @map("session_token_hash")
  status           ExtensionSessionStatus @default(ACTIVE)
  lastHeartbeatAt  DateTime               @map("last_heartbeat_at")
  expiresAt        DateTime               @map("expires_at")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  organization     Organization           @relation(fields: [organizationId], references: [id])
  user             User                   @relation(fields: [userId], references: [id])
  shop             Shop?                  @relation(fields: [shopId], references: [id])
  ingestionBatches IngestionBatch[]

  @@index([organizationId])
  @@index([userId])
  @@index([shopId])
  @@map("extension_sessions")
}

model IngestionBatch {
  id                   String               @id @default(uuid()) @db.Uuid
  organizationId       String               @map("organization_id") @db.Uuid
  shopId               String?              @map("shop_id") @db.Uuid
  extensionSessionId   String               @map("extension_session_id") @db.Uuid
  captureMode          CaptureMode          @map("capture_mode")
  pageType             String               @map("page_type")
  marketplace          String
  payloadSchemaVersion String               @map("payload_schema_version")
  status               IngestionBatchStatus @default(ACCEPTED)
  capturedAt           DateTime             @map("captured_at")
  processedAt          DateTime?            @map("processed_at")
  errorCode            String?              @map("error_code")
  errorMessage         String?              @map("error_message")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  organization         Organization         @relation(fields: [organizationId], references: [id])
  shop                 Shop?                @relation(fields: [shopId], references: [id])
  extensionSession     ExtensionSession     @relation(fields: [extensionSessionId], references: [id])
  rawPayloadObjects    RawPayloadObject[]

  @@index([organizationId])
  @@index([shopId])
  @@index([extensionSessionId])
  @@index([organizationId, status])
  @@index([shopId, capturedAt])
  @@map("ingestion_batches")
}

model RawPayloadObject {
  id               String                 @id @default(uuid()) @db.Uuid
  organizationId   String                 @map("organization_id") @db.Uuid
  shopId           String?                @map("shop_id") @db.Uuid
  ingestionBatchId String                 @map("ingestion_batch_id") @db.Uuid
  storageKey       String                 @map("storage_key")
  payloadHash      String                 @map("payload_hash")
  sizeBytes        Int                    @map("size_bytes")
  retentionUntil   DateTime               @map("retention_until")
  status           RawPayloadObjectStatus @default(STORED)
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  organization     Organization           @relation(fields: [organizationId], references: [id])
  shop             Shop?                  @relation(fields: [shopId], references: [id])
  ingestionBatch   IngestionBatch         @relation(fields: [ingestionBatchId], references: [id])

  @@unique([ingestionBatchId, payloadHash])
  @@index([organizationId])
  @@index([shopId])
  @@index([ingestionBatchId])
  @@index([retentionUntil])
  @@map("raw_payload_objects")
}
