generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum InternalUserRole {
  PLATFORM_ADMIN
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
}

enum MembershipRole {
  OWNER
  MANAGER
  STAFF
  AGENCY_ADMIN
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum PlanStatus {
  ACTIVE
  INACTIVE
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  PENDING_ACTIVATION
  ACTIVE
  PAST_DUE
  GRACE_PERIOD
  CANCELED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PENDING_PAYMENT
  PAID
  FAILED
  EXPIRED
  VOID
  REFUNDED
}

enum MarketplaceCode {
  SHOPEE
  TIKTOK_SHOP
}

enum ShopStatus {
  ACTIVE
  DISCONNECTED
  SUSPENDED
}

enum ExtensionSessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum CaptureMode {
  OWNED
  PUBLIC
}

enum IngestionBatchStatus {
  ACCEPTED
  FAILED
  PROCESSING
  COMPLETED
}

enum RawPayloadObjectStatus {
  STORED
  FAILED
  EXPIRED
}

enum CategoryFeeStoreType {
  NON_STAR
  STAR
  MALL
}

model User {
  id                   String          @id @default(uuid()) @db.Uuid
  email                String          @unique
  passwordHash         String          @map("password_hash")
  name                 String
  status               UserStatus      @default(ACTIVE)
  internalRole         InternalUserRole? @map("internal_role")
  lastLoginAt          DateTime?       @map("last_login_at")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  ownedOrganizations   Organization[]  @relation("OrganizationOwner")
  memberships          Membership[]
  userSessions         UserSession[]
  extensionSessions    ExtensionSession[]
  invitedMemberships   Membership[]    @relation("MembershipInvitedBy")

  @@map("users")
}

model Organization {
  id             String             @id @default(uuid()) @db.Uuid
  name           String
  slug           String             @unique
  ownerUserId    String             @map("owner_user_id") @db.Uuid
  isInternal     Boolean            @default(false) @map("is_internal")
  status         OrganizationStatus @default(ACTIVE)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  ownerUser      User               @relation("OrganizationOwner", fields: [ownerUserId], references: [id])
  memberships    Membership[]
  userSessions   UserSession[]
  subscription   Subscription?
  shops          Shop[]
  extensionSessions ExtensionSession[]
  ingestionBatches IngestionBatch[]
  rawPayloadObjects RawPayloadObject[]
  billingInvoices BillingInvoice[]
  entitlementSnapshot OrganizationEntitlementSnapshot?

  @@index([ownerUserId])
  @@map("organizations")
}

model Membership {
  id               String           @id @default(uuid()) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  userId           String           @map("user_id") @db.Uuid
  role             MembershipRole
  status           MembershipStatus @default(ACTIVE)
  invitedByUserId  String?          @map("invited_by_user_id") @db.Uuid
  joinedAt         DateTime?        @map("joined_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  organization     Organization     @relation(fields: [organizationId], references: [id])
  user             User             @relation(fields: [userId], references: [id])
  invitedByUser    User?            @relation("MembershipInvitedBy", fields: [invitedByUserId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, role])
  @@map("memberships")
}

model UserSession {
  id                   String        @id @default(uuid()) @db.Uuid
  userId               String        @map("user_id") @db.Uuid
  activeOrganizationId String        @map("active_organization_id") @db.Uuid
  sessionTokenHash     String        @unique @map("session_token_hash")
  expiresAt            DateTime      @map("expires_at")
  lastSeenAt           DateTime      @map("last_seen_at")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  user                 User          @relation(fields: [userId], references: [id])
  activeOrganization   Organization  @relation(fields: [activeOrganizationId], references: [id])

  @@index([userId])
  @@index([activeOrganizationId])
  @@map("user_sessions")
}

model Plan {
  id              String             @id @default(uuid()) @db.Uuid
  code            String             @unique
  name            String
  isInternal      Boolean            @default(false) @map("is_internal")
  billingInterval BillingInterval    @map("billing_interval")
  priceAmount     Int                @default(0) @map("price_amount")
  currency        String             @default("IDR")
  sortOrder       Int                @default(0) @map("sort_order")
  shopLimit       Int                @map("shop_limit")
  memberLimit     Int                @map("member_limit")
  historyDays     Int                @map("history_days")
  featuresJson    Json               @map("features_json")
  status          PlanStatus         @default(ACTIVE)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  subscriptions   Subscription[]
  billingInvoices BillingInvoice[]

  @@map("plans")
}

model Subscription {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @unique @map("organization_id") @db.Uuid
  planId            String             @map("plan_id") @db.Uuid
  status            SubscriptionStatus @default(TRIALING)
  startsAt          DateTime           @map("starts_at")
  endsAt            DateTime?          @map("ends_at")
  currentPeriodStart DateTime?         @map("current_period_start")
  currentPeriodEnd  DateTime?          @map("current_period_end")
  gracePeriodEnd    DateTime?          @map("grace_period_end")
  cancelAtPeriodEnd Boolean            @default(false) @map("cancel_at_period_end")
  activatedAt       DateTime?          @map("activated_at")
  canceledAt        DateTime?          @map("canceled_at")
  expiredAt         DateTime?          @map("expired_at")
  autoRenew         Boolean            @default(false) @map("auto_renew")
  provider          String
  providerReference String?            @map("provider_reference")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  organization      Organization       @relation(fields: [organizationId], references: [id])
  plan              Plan               @relation(fields: [planId], references: [id])
  invoices          BillingInvoice[]
  entitlementSnapshots OrganizationEntitlementSnapshot[]

  @@index([planId])
  @@index([organizationId, status])
  @@map("subscriptions")
}

model BillingInvoice {
  id                 String                    @id @default(uuid()) @db.Uuid
  invoiceNumber      String                    @unique @map("invoice_number")
  organizationId     String                    @map("organization_id") @db.Uuid
  subscriptionId     String?                   @map("subscription_id") @db.Uuid
  planId             String                    @map("plan_id") @db.Uuid
  billingInterval    BillingInterval           @map("billing_interval")
  amount             Int
  currency           String                    @default("IDR")
  status             InvoiceStatus             @default(DRAFT)
  orderId            String                    @unique @map("order_id")
  gatewayOrderId     String?                   @unique @map("gateway_order_id")
  description        String?
  issuedAt           DateTime?                 @map("issued_at")
  dueAt              DateTime?                 @map("due_at")
  paidAt             DateTime?                 @map("paid_at")
  failedAt           DateTime?                 @map("failed_at")
  expiredAt          DateTime?                 @map("expired_at")
  voidedAt           DateTime?                 @map("voided_at")
  metadataJson       Json                      @default("{}") @map("metadata_json")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  organization       Organization              @relation(fields: [organizationId], references: [id])
  subscription       Subscription?             @relation(fields: [subscriptionId], references: [id])
  plan               Plan                      @relation(fields: [planId], references: [id])
  paymentTransaction BillingPaymentTransaction?
  callbackDeliveries BillingCallbackDelivery[]

  @@index([organizationId, status])
  @@index([subscriptionId])
  @@map("billing_invoices")
}

model BillingPaymentTransaction {
  id                     String          @id @default(uuid()) @db.Uuid
  invoiceId              String          @unique @map("invoice_id") @db.Uuid
  provider               String
  paymentService         String          @map("payment_service")
  orderId                String          @map("order_id")
  gatewayOrderId         String?         @unique @map("gateway_order_id")
  paymentType            String?         @map("payment_type")
  transactionStatus      String?         @map("transaction_status")
  callbackStatus         String?         @map("callback_status")
  redirectUrl            String?         @map("redirect_url")
  snapToken              String?         @map("snap_token")
  rawChargeResponseJson  Json?           @map("raw_charge_response_json")
  lastLookupResponseJson Json?           @map("last_lookup_response_json")
  lastCallbackPayloadJson Json?          @map("last_callback_payload_json")
  lastCallbackReceivedAt DateTime?       @map("last_callback_received_at")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  invoice                BillingInvoice  @relation(fields: [invoiceId], references: [id])

  @@index([orderId])
  @@index([transactionStatus])
  @@map("billing_payment_transactions")
}

model BillingCallbackDelivery {
  id                    String         @id @default(uuid()) @db.Uuid
  invoiceId             String?        @map("invoice_id") @db.Uuid
  gatewayOrderId        String?        @map("gateway_order_id")
  deliveryId            String         @map("delivery_id")
  attempt               Int            @default(1)
  eventType             String?        @map("event_type")
  signatureValid        Boolean        @default(false) @map("signature_valid")
  processedSuccessfully Boolean        @default(false) @map("processed_successfully")
  httpResponseCode      Int?           @map("http_response_code")
  receivedAt            DateTime       @default(now()) @map("received_at")
  processedAt           DateTime?      @map("processed_at")
  headersJson           Json           @default("{}") @map("headers_json")
  payloadJson           Json           @default("{}") @map("payload_json")
  errorMessage          String?        @map("error_message")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  invoice               BillingInvoice? @relation(fields: [invoiceId], references: [id])

  @@unique([deliveryId, attempt])
  @@index([invoiceId])
  @@index([gatewayOrderId])
  @@index([processedSuccessfully])
  @@index([receivedAt])
  @@map("billing_callback_deliveries")
}

model OrganizationEntitlementSnapshot {
  id                 String        @id @default(uuid()) @db.Uuid
  organizationId     String        @unique @map("organization_id") @db.Uuid
  subscriptionId     String?       @map("subscription_id") @db.Uuid
  planCode           String        @map("plan_code")
  subscriptionStatus SubscriptionStatus @map("subscription_status")
  featuresJson       Json          @default("{}") @map("features_json")
  quotasJson         Json          @default("{}") @map("quotas_json")
  computedAt         DateTime      @default(now()) @map("computed_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  organization       Organization  @relation(fields: [organizationId], references: [id])
  subscription       Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([planCode])
  @@map("organization_entitlement_snapshots")
}

model Marketplace {
  id        String          @id @default(uuid()) @db.Uuid
  code      MarketplaceCode @unique
  name      String
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  shops     Shop[]
  categoryFees MarketplaceCategoryFee[]

  @@map("marketplaces")
}

model MarketplaceCategoryFee {
  id                String               @id @default(uuid()) @db.Uuid
  marketplaceId     String               @map("marketplace_id") @db.Uuid
  storeType         CategoryFeeStoreType @map("store_type")
  primaryCategory   String               @map("primary_category")
  secondaryCategory String?              @map("secondary_category")
  categoryName      String               @map("category_name")
  feePercent        Float                @map("fee_percent")
  gratisOngkirPctRegular Float           @default(0) @map("gratis_ongkir_pct_regular")
  gratisOngkirCapRegular Float           @default(0) @map("gratis_ongkir_cap_regular")
  gratisOngkirPctSpecial Float           @default(0) @map("gratis_ongkir_pct_special")
  gratisOngkirCapSpecial Float           @default(0) @map("gratis_ongkir_cap_special")
  isActive          Boolean              @default(true) @map("is_active")
  notes             String?
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  marketplace       Marketplace          @relation(fields: [marketplaceId], references: [id])

  @@unique([marketplaceId, storeType, primaryCategory, secondaryCategory, categoryName], map: "mcf_market_store_cat_unique")
  @@index([marketplaceId, storeType, isActive], map: "mcf_market_store_active_idx")
  @@index([marketplaceId], map: "mcf_market_idx")
  @@map("marketplace_category_fees")
}

model Shop {
  id                String             @id @default(uuid()) @db.Uuid
  organizationId    String             @map("organization_id") @db.Uuid
  marketplaceId     String             @map("marketplace_id") @db.Uuid
  externalId        String             @map("external_id")
  name              String?
  status            ShopStatus         @default(ACTIVE)
  metadataJson      Json               @default("{}") @map("metadata_json")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  organization      Organization       @relation(fields: [organizationId], references: [id])
  marketplace       Marketplace        @relation(fields: [marketplaceId], references: [id])
  extensionSessions ExtensionSession[]
  ingestionBatches  IngestionBatch[]
  rawPayloadObjects RawPayloadObject[]

  @@unique([organizationId, marketplaceId, externalId])
  @@index([organizationId])
  @@index([marketplaceId])
  @@map("shops")
}

model ExtensionSession {
  id               String                 @id @default(uuid()) @db.Uuid
  organizationId   String                 @map("organization_id") @db.Uuid
  userId           String                 @map("user_id") @db.Uuid
  shopId           String?                @map("shop_id") @db.Uuid
  deviceLabel      String                 @map("device_label")
  extensionVersion String                 @map("extension_version")
  sessionTokenHash String                 @unique @map("session_token_hash")
  status           ExtensionSessionStatus @default(ACTIVE)
  lastHeartbeatAt  DateTime               @map("last_heartbeat_at")
  expiresAt        DateTime               @map("expires_at")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  organization     Organization           @relation(fields: [organizationId], references: [id])
  user             User                   @relation(fields: [userId], references: [id])
  shop             Shop?                  @relation(fields: [shopId], references: [id])
  ingestionBatches IngestionBatch[]

  @@index([organizationId])
  @@index([userId])
  @@index([shopId])
  @@map("extension_sessions")
}

model IngestionBatch {
  id                   String               @id @default(uuid()) @db.Uuid
  organizationId       String               @map("organization_id") @db.Uuid
  shopId               String?              @map("shop_id") @db.Uuid
  extensionSessionId   String               @map("extension_session_id") @db.Uuid
  captureMode          CaptureMode          @map("capture_mode")
  pageType             String               @map("page_type")
  marketplace          String
  payloadSchemaVersion String               @map("payload_schema_version")
  status               IngestionBatchStatus @default(ACCEPTED)
  capturedAt           DateTime             @map("captured_at")
  processedAt          DateTime?            @map("processed_at")
  errorCode            String?              @map("error_code")
  errorMessage         String?              @map("error_message")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  organization         Organization         @relation(fields: [organizationId], references: [id])
  shop                 Shop?                @relation(fields: [shopId], references: [id])
  extensionSession     ExtensionSession     @relation(fields: [extensionSessionId], references: [id])
  rawPayloadObjects    RawPayloadObject[]

  @@index([organizationId])
  @@index([shopId])
  @@index([extensionSessionId])
  @@index([organizationId, status])
  @@index([shopId, capturedAt])
  @@map("ingestion_batches")
}

model RawPayloadObject {
  id               String                 @id @default(uuid()) @db.Uuid
  organizationId   String                 @map("organization_id") @db.Uuid
  shopId           String?                @map("shop_id") @db.Uuid
  ingestionBatchId String                 @map("ingestion_batch_id") @db.Uuid
  storageKey       String                 @map("storage_key")
  payloadHash      String                 @map("payload_hash")
  sizeBytes        Int                    @map("size_bytes")
  retentionUntil   DateTime               @map("retention_until")
  status           RawPayloadObjectStatus @default(STORED)
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  organization     Organization           @relation(fields: [organizationId], references: [id])
  shop             Shop?                  @relation(fields: [shopId], references: [id])
  ingestionBatch   IngestionBatch         @relation(fields: [ingestionBatchId], references: [id])

  @@unique([ingestionBatchId, payloadHash])
  @@index([organizationId])
  @@index([shopId])
  @@index([ingestionBatchId])
  @@index([retentionUntil])
  @@map("raw_payload_objects")
}
